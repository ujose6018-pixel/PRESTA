rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS SIMPLIFICADAS (Vigencia hasta 2035)
    // Permite lectura y escritura global para sincronización total entre dispositivos
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2035, 5, 9);
    }
  }
}
